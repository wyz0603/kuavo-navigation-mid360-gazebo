baseCost
{
  ; control weight matrix
  Q
  {
    ; input costs for the different types of arm base DOFs
    base
    {
      wheelBasedMobileManipulator
      {
        scaling 1e0

        (0,0)  20.0  ; base x position
        (1,1)  20.0  ; base y position
        (2,2)  20.0  ; base yaw 
      }
      wheelWorldBasedMobileManipulator
      {
        scaling 1e0

        (0,0)  100.0  ; base x position
        (1,1)  100.0  ; base y position
        (2,2)  100.0  ; base yaw 
      }
    }

    ; state costs for the arm DOFs
    arm
    {
      scaling 1e0

      (0,0)    20.0  ; knee_pitch
      (1,1)    20.0  ; leg_pitch
      (2,2)    20.0  ; waist_pitch
      (3,3)    20.0  ; waist_yaw_link

