# Request: user query string and filesystem path to image
string query
string image_path  # Filesystem path to image file

---
# Response fields
bool success        # Service call success status
int32 error_code    # Error code (0 = success, 1 = empty query, 2 = service unavailable, 3 = invalid image)
string message      # Status or error message
string uuid         # UUID for tracking this query (empty if failed)
