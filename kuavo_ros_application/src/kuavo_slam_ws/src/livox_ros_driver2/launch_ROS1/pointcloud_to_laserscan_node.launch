<launch>

  <arg name="scan_topic" default="/livox/scan" />
  <arg name="cloud_topic" default="/livox/cloud" />
  <arg name="target_frame" default="livox_frame" />

  <!-- <node pkg="pointcloud_to_laserscan" type="pointcloud_to_laserscan_node" name="pointcloud_to_laserscan_node">
    <remap from="cloud_in" to="$(arg cloud_topic)"/>
    <remap from="scan" to="$(arg scan_topic)"/>
    <param name="target_frame" value="$(arg target_frame)"/>
  </node> -->

  <node pkg="pointcloud_to_laserscan" type="pointcloud_to_laserscan_node" name="pointcloud_to_laserscan">
      <remap from="scan" to="$(arg scan_topic)"/>
      <remap from="cloud_in" to="$(arg cloud_topic)"/>
      <param name="target_frame" value="$(arg target_frame)"/>
      
      <rosparam>
          transform_tolerance: 0.01
          min_height: 0.0
          max_height: 0.2

          angle_min: -3.14159 # -M_PI/2
          angle_max: 3.14159 # M_PI/2
          angle_increment: 0.0087 # M_PI/360.0
          scan_time: 10
          range_min: 0.30
          range_max: 30.0
          use_inf: true
          inf_epsilon: 1.0
          
          concurrency_level: 1
      </rosparam>
  </node>
</launch>
